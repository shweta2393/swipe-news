# Expo (client-safe)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions only — never bundle in the app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEWS_API_KEY=your-newsapi-key
OPENAI_API_KEY=your-openai-key

# Summarization (Edge Functions) — free-tier defaults
# local = no OpenAI (uses title/description excerpt). Recommended for free tier.
# llm   = OpenAI only. auto = try LLM, fall back to local on quota errors.
SUMMARIZE_MODE=local
SUMMARIZE_BATCH_SIZE=50
# Only used when SUMMARIZE_MODE is llm or auto
SUMMARIZE_REQUEST_DELAY_MS=1500
OPENAI_MODEL=gpt-4o-mini

# Optional: protect cron-triggered functions
CRON_SECRET=random-secret-for-scheduled-jobs
